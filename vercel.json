{
  "version": 2,
  "builds": [
    { "src": "api/checkout.js", "use": "@vercel/node" },
    { "src": "api/webhook.js", "use": "@vercel/node" },
    { "src": "api/coaching-checkout.js", "use": "@vercel/node" },
    { "src": "api/portal-session.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" },
    { "src": "icons/*.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/checkout", "dest": "/api/checkout.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/coaching-checkout", "dest": "/api/coaching-checkout.js" },
    { "src": "/api/portal-session", "dest": "/api/portal-session.js" },
    { "src": "/onboarding.html", "dest": "/onboarding.html" },
    { "src": "/dashboard.html", "dest": "/dashboard.html" },
    { "src": "/login.html", "dest": "/login.html" },
    { "src": "/signup.html", "dest": "/signup.html" },
    { "src": "/admin.html", "dest": "/admin.html" },
    { "src": "/coach-signup.html", "dest": "/coach-signup.html" },
    { "src": "/terms.html", "dest": "/terms.html" },
    { "src": "/reset-password.html", "dest": "/reset-password.html" },
    { "src": "/icons/(.*)", "dest": "/icons/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
